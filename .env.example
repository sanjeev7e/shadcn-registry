# ── Auth mode ────────────────────────────────────────────────────────────────
# "public"  → no token required, anyone can access components (default)
# "static"  → single shared token via REGISTRY_TOKEN
# "dynamic" → per-user tokens managed via /api/tokens; use /api/r/{name} to fetch components
REGISTRY_AUTH_MODE=static

# ── Static mode ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
REGISTRY_TOKEN=your_secret_token_here

# ── Dynamic mode ──────────────────────────────────────────────────────────────
# Admin secret to call /api/tokens (create / list / revoke)
# Generate with: openssl rand -hex 32
REGISTRY_ADMIN_SECRET=your_admin_secret_here
